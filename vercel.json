{
  "buildCommand": null,
  "installCommand": null,
  "framework": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/$1"
    },
    {
      "source": "/",
      "destination": "/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/home.html",
      "destination": "/index.html",
      "permanent": true,
      "statusCode": 301
    }
  ]
}
